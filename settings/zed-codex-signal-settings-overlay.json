{
  "theme": {
    "mode": "system",
    "light": "Codex Signal Prism Light",
    "dark": "Codex Signal Dark"
  },
  "icon_theme": {
    "mode": "system",
    "light": "Codex Signal Tech Icons Light",
    "dark": "Codex Signal Tech Icons Dark"
  },
  "ui_font_family": ".SystemUIFont",
  "ui_font_weight": 500,
  "ui_font_size": 14,
  "buffer_font_family": ".SF Mono",
  "buffer_font_size": 14,
  "buffer_font_weight": 600,
  "buffer_line_height": "standard",
  "agent_ui_font_size": 14,
  "agent_buffer_font_size": 13,
  "active_pane_modifiers": {
    "border_size": 0.75,
    "inactive_opacity": 0.92
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_branch_name": true,
    "show_project_items": true,
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_user_menu": true,
    "show_sign_in": false,
    "show_menus": false,
    "button_layout": "platform_default"
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": true,
    "show_tab_bar_buttons": true
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "activate_on_close": "history",
    "show_close_button": "hover",
    "show_diagnostics": "all"
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true,
    "selections_menu": false,
    "agent_review": true,
    "code_actions": false
  },
  "current_line_highlight": "line",
  "preferred_line_length": 100,
  "soft_wrap": "none",
  "show_wrap_guides": true,
  "wrap_guides": [
    100,
    120
  ],
  "gutter": {
    "line_numbers": true,
    "runnables": true,
    "breakpoints": true,
    "folds": true,
    "min_line_number_digits": 4
  },
  "relative_line_numbers": "disabled",
  "indent_guides": {
    "enabled": true,
    "line_width": 1,
    "active_line_width": 2,
    "coloring": "indent_aware",
    "background_coloring": "disabled"
  },
  "show_whitespaces": "boundary",
  "scrollbar": {
    "show": "auto",
    "cursors": true,
    "git_diff": true,
    "search_results": true,
    "selected_text": true,
    "selected_symbol": true,
    "diagnostics": "all",
    "axes": {
      "horizontal": false,
      "vertical": true
    }
  },
  "minimap": {
    "show": "auto",
    "thumb": "always",
    "thumb_border": "left_only",
    "current_line_highlight": "line"
  },
  "bottom_dock_layout": "contained",
  "project_panel": {
    "dock": "right",
    "default_width": 300,
    "entry_spacing": "standard",
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 16,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true,
    "bold_folder_labels": false,
    "scrollbar": {
      "show": "auto",
      "horizontal_scroll": false
    },
    "indent_guides": {
      "show": "always"
    },
    "show_diagnostics": "all",
    "sort_mode": "directories_first",
    "hide_hidden": true
  },
  "outline_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right",
    "button": true,
    "scrollbar": {
      "show": "auto"
    }
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false
  },
  "agent": {
    "dock": "left",
    "sidebar_side": "left",
    "flexible": false
  },
  "terminal": {
    "dock": "bottom",
    "font_family": ".SF Mono",
    "font_size": 13,
    "line_height": "standard",
    "minimum_contrast": 80,
    "button": true,
    "toolbar": {
      "breadcrumbs": true
    },
    "scrollbar": {
      "show": "auto"
    }
  }
}
